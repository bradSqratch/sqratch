# SQRATCH environment variable template.
# Copy to .env and fill in real values for local development.
# Every variable here is documented in detail in docs/env-vars.md.
# Never commit a filled-in .env file. Never put a server secret in a
# NEXT_PUBLIC_* variable — those are exposed to the browser.

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Only needed if your Prisma CLI workflow uses a direct (non-pooled) connection.
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Optional pooled-connection tuning (see src/lib/prisma.ts) — defaults are fine locally.
# PG_POOL_MAX=5
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECT_TIMEOUT_MS=10000
# PG_SSL_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------------------
# Authentication (required)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# Server-only HMAC pepper for email verification codes. Generate a random
# 32-byte-or-longer value; production must not issue verification codes
# without it.
EMAIL_VERIFICATION_CODE_PEPPER=replace-with-32-byte-secret

DOMAIN=http://localhost:3000
# Optional fallback for DOMAIN/NEXTAUTH_URL in a couple of link-building code paths.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Encryption (required for Shopify features)
# ---------------------------------------------------------------------------
# Server-only, stable key used to encrypt Shopify access/refresh tokens at
# rest. Manage independently from NEXTAUTH_SECRET. Rotating it makes existing
# encrypted credentials unreadable until stores reconnect or a key-rotation
# migration is run.
APP_ENCRYPTION_KEY=replace-with-32-byte-secret

# ---------------------------------------------------------------------------
# Shopify (required for Shopify features)
# ---------------------------------------------------------------------------
# public = the reviewed embedded app (shopify.app.toml); custom = the test
# app (shopify.app.custom.toml). Never mix client IDs between the two.
SHOPIFY_APP_DISTRIBUTION=custom
SHOPIFY_API_KEY=your-shopify-client-id
SHOPIFY_API_SECRET=your-shopify-client-secret
SHOPIFY_APP_URL=http://localhost:3000

# Scopes are not configured through an environment variable — see
# docs/env-vars.md for where the required scopes must be kept aligned.

# ---------------------------------------------------------------------------
# Supabase storage (required for uploads)
# ---------------------------------------------------------------------------
SUPABASE_STORAGE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_URL is an accepted fallback for SUPABASE_STORAGE_URL.
SUPABASE_STORAGE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_SERVICE_ROLE_KEY is an accepted fallback for SUPABASE_STORAGE_SERVICE_ROLE_KEY.

SUPABASE_EXPERIENCE_COVER_BUCKET=experience-covers
SUPABASE_LESSON_VIDEO_BUCKET=lesson-videos
SUPABASE_CAMPAIGN_VIDEO_BUCKET=campaign-videos
SUPABASE_USER_AVATAR_BUCKET=user-avatars
SUPABASE_BRAND_ASSET_BUCKET=brand-assets

MAX_UPLOAD_MB=5
MAX_VIDEO_UPLOAD_MB=250

# Optional: how long a signed lesson-video playback URL stays valid.
# Defaults to a sane value in code if unset — see src/lib/lesson-video-playback.ts.
# LESSON_VIDEO_SIGNED_URL_TTL_SECONDS=3600

# Optional: legacy asset hosting, used only by QR-batch image generation.
# CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ---------------------------------------------------------------------------
# Email (required for signup/verification/notification emails)
# ---------------------------------------------------------------------------
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your-mailtrap-user
MAILTRAP_PASSWORD=your-mailtrap-password
ADMIN_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Internal cron/workers (required for scheduled jobs)
# ---------------------------------------------------------------------------
# Sent as the x-cron-secret header by the external scheduler that calls
# /api/internal/email-worker and /api/internal/reconcile-redemptions.
CRON_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Analytics (optional)
# ---------------------------------------------------------------------------
# A Google Analytics measurement ID is not a secret, but use your own value
# rather than a production identifier in local/shared configuration.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Seed script (optional — local/dev only; never set ALLOW_PROD_SEED in production)
# ---------------------------------------------------------------------------
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=replace-with-a-strong-password
# ALLOW_PROD_SEED=false
